{{ include('common/header.twig') }}

<div class="container">
  <h1>Vidéos</h1>
  <div>
    <table id="table" class="table table-bordered table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th scope="col" class="minw">Id</th>
          <th scope="col">Vidéo</th>
          <th scope="col">Nom</th>
          <th scope="col">Groupe</th>
          <th scope="col">Évènement</th>
          <th scope="col">Lieu</th>
          <th scope="col">Créa</th>
          <th scope="col">Modif</th>
        </tr>
      </thead>
      <tbody>
      {#
      {% for video in videos %}
        <tr>
          <td>{{ video.idVideo }}</td>
          <td><img src="{{ video.ThumbUrl(80) }}" alt=""/></td>
          <td>{{ video.name }}</td>
          <td>{% if video.idGroupe %}<a href="{{ video.Groupe.url }}">{{ video.groupe.name }}</a>{% endif %}</td>
          <td>{% if video.idEvent %}<a href="{{ video.Event.url }}">{{ video.event.name }}</a><br/>{{ video.event.date|date('d/m/Y') }}{% endif %}</td>
          <td>{% if video.idLieu %}<a href="{{ video.lieu.url }}">{{ video.lieu.name }}</a><br>{{ video.Lieu.idDepartement }} {{ video.lieu.city.name }}{% endif %}</td>
          <td>{{ video.createdAt|date('d/m/Y') }}</td>
          <td>{{ video.modifiedAt|date('d/m/Y') }}</td>
        </tr>
      {% endfor %}
      #}
      </tbody>
    </table>
  </div>
</div>

{{ include('common/footer.twig') }}
