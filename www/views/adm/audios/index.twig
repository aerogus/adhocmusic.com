{{ include('common/header.twig') }}

<div class="container">
  <h1>Audios</h1>
  <div>
    <table id="table" class="table table-bordered table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th scope="col" class="minw">Id</th>
          <th scope="col">Nom</th>
          <th scope="col">Groupe</th>
          <th scope="col">Évènement</th>
          <th scope="col">Lieu</th>
          <th scope="col">Créa</th>
          <th scope="col">Modif</th>
        </tr>
      </thead>
      <tbody>
      {#
      {% for audio in audios %}
        <tr>
          <td>{{ audio.idAudio }}</td>
          <td>{{ audio.name }}</td>
          <td>{% if audio.idGroupe %}<a href="{{ audio.groupe.url }}">{{ audio.groupe.name }}</a>{% endif %}</td>
          <td>{% if audio.idEvent %}<a href="{{ audio.event.url }}">{{ audio.event.name }}</a><br/>{{ audio.event.date|date('d/m/Y') }}{% endif %}</td>
          <td>{% if audio.idLieu %}<a href="{{ audio.lieu.url }}">{{ audio.lieu.name }}</a><br>{{ audio.lieu.idDepartement }} {{ audio.lieu.city.name }}{% endif %}</td>
          <td>{{ audio.createdAt|date('d/m/Y') }}</td>
          <td>{{ audio.modifiedAt|date('d/m/Y') }}</td>
        </tr>
      {% endfor %}
      #}
      </tbody>
    </table>
  </div>
</div>

{{ include('common/footer.twig') }}
